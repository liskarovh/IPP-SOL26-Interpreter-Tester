*** super should allow access to parent-created attribute when child shadows it by method.
+++ VALID_SELFSUP
!C! 0
!I! 0
>>> 1

class Parent : Object {
make [ |
  _ := self p: 'hello1'.
]
}

class Main : Parent {

p [ |
  _ := 'foo1'.
]

readParentAttr [ |
  _ := super make.
  r := super p.
]
}

class Main : Object {

  run [ |
    r := self readParentAttr.
_ := r print.
  ]
  }
