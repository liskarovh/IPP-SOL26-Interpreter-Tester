+++ ARITHMETIC
*** Test celociselne aritmetiky a prevodu na retezec
!C! 0
!I! 0
>>> 2

class Main : Object {
    run [ |
        a := 10.
        b := 3.
        sum := a plus: b.
        diff := a minus: b.
        prod := a multiplyBy: b.
        quot := a divBy: b.
        _ := (sum asString) print.
        _ := (diff asString) print.
        _ := (prod asString) print.
        _ := (quot asString) print.
    ]
}
