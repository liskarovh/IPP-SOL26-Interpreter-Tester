+++ BASIC
*** Test hodnoty nil - isNil, asString, identita jedinavka
!C! 0
!I! 0
>>> 1

class Main : Object {
    run [ |
        n := nil.
        _ := (n asString) print.
        _ := '\n' print.

        x := (n isNil) asString.
        _ := x print.
        _ := '\n' print.

        "nil je jedinavek - identicalTo: vraci true"
        same := n identicalTo: nil.
        _ := (same asString) print.
    ]
}
