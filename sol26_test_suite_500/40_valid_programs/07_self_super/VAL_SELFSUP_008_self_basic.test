class Main : Object {
setAndGet [ :v |
  _ := self val: v.
  _ := self val.
]
makeBlock [ :v |
  _ := self val: v.
  b := [| r := self val. ].
  _ := b.
]

  run [ |
    b := self makeBlock: '2'.
r := b value.
_ := r print.
  ]
  }